{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "ES2022",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "frida-gum", "frida-java-bridge", "frida-objc-bridge", "frida-swift-bridge"],
    "paths": {
      "frooky/shared": ["./shared/index.ts"],
      "frooky/android": ["./android/index.ts"],
      "frooky/ios": ["./ios/index.ts"],
      "frooky/native": ["./native/index.ts"],
      "frooky/zod": ["./shared/inputParsing/zodSchemas/index.ts"]
    }
  },
  "include": ["./**/*"]
}

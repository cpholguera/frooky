{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "ES2022",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "frida-gum",
      "frida-java-bridge",
      "frida-objc-bridge",
      "frida-swift-bridge"
    ],
    "baseUrl": "./",
    "paths": {
      "frooky": ["./types"]
    }
  },
  "include": [
    "ios/**/*",
    "android/**/*",
    "shared/**/*",
    "types/**/*",
    "docs/**/*",
    "examples/**/*",
    "FrookyApp.ts"
  ]
}